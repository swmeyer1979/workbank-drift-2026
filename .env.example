# --- Anthropic (Opus 4.7) ---
# OAuth subscription path preferred. If ANTHROPIC_OAUTH_TOKEN is set, pipeline
# exchanges it for a subscription-billed key via
# POST https://api.anthropic.com/api/oauth/claude_cli/create_api_key.
# Requires org:create_api_key scope (re-auth Claude Code CLI if missing).
ANTHROPIC_OAUTH_TOKEN=

# Fallback: API-billed key (burns API credits, not subscription)
ANTHROPIC_API_KEY=

# --- Google (Gemini 3 Pro) ---
GOOGLE_API_KEY=

# --- OpenAI (GPT-5.2) ---
OPENAI_API_KEY=
